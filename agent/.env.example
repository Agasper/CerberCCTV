# URL админки (App Platform выдаёт вида https://<app>.ondigitalocean.app)
ADMIN_URL=https://your-app.ondigitalocean.app

# Токен агента: выпустите на странице «Настройки» админки
AGENT_TOKEN=

# Необязательное:
# Максимальный размер очереди незагруженных клипов на диске, МБ
#OUTBOX_MAX_MB=2048
# Уровень логов: DEBUG | INFO | WARNING
#LOG_LEVEL=INFO
